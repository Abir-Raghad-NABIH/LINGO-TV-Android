<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#e94560"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textColor="#ffffff"
            android:textSize="24sp"
            android:gravity="center"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👩 Mon Avatar IA"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- AVATAR PHOTO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#111111"
        android:padding="16dp">

        <!-- PHOTO AVATAR -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp">

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:background="#333333"/>

            <TextView
                android:id="@+id/tvAvatarEmoji"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:text="👩"
                android:textSize="64sp"
                android:gravity="center"
                android:background="#333333"/>

        </FrameLayout>

        <!-- BOUTONS PHOTO -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnTakePhoto"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="📷 Prendre photo"
                android:textColor="#ffffff"
                android:backgroundTint="#e94560"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnGallery"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="🖼️ Galerie"
                android:textColor="#ffffff"
                android:backgroundTint="#333333"
                android:textSize="12sp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvAvatarName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon Avatar"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/tvAvatarStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🟢 En ligne — Prête à discuter"
            android:textColor="#4CAF50"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

    </LinearLayout>

    <!-- CHAT -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp">

        <LinearLayout
            android:id="@+id/chatContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

    </ScrollView>

    <!-- INPUT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#111111"
        android:padding="8dp"
        android:gravity="center_vertical">

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:hint="Pose une question à ton avatar..."
            android:textColor="#ffffff"
            android:textColorHint="#888888"
            android:background="@drawable/edit_text_bg"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:inputType="text"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnMic"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:text="🎤"
            android:textSize="18sp"
            android:backgroundTint="#333333"
            android:layout_marginStart="4dp"
            android:padding="0dp"/>

        <Button
            android:id="@+id/btnSend"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:text="➤"
            android:textColor="#ffffff"
            android:textSize="18sp"
            android:backgroundTint="#e94560"
            android:layout_marginStart="4dp"
            android:padding="0dp"/>

    </LinearLayout>

</LinearLayout>